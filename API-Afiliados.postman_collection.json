    {
      "name": "Saques",
      "item": [
        {
          "name": "Solicitar saque",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) {",
                  "        pm.collectionVariables.set('withdrawal_id', json.id);",
                  "        console.log('withdrawal_id salvo:', json.id);",
